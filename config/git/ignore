# Global .gitignore file to keep random crap out of my repos
#
# Symlinked to ~/.config/git/ignore via Dotbot; picked up automatically
# by Git as the global excludes file (no manual git config needed).

#
# Vagrant stuff
*.box
/.vagrant/

#
# Bundled Plugins
node_modules/

#
# Temporary Files
*~
*.swp
*.orig

#
# Thumbnails
._*

#
# Config Files
.rvmrc
.ruby-version
.ruby-gemset

#
# Compiled source
*.com
*.class
*.dll
*.exe
*.o
*.so
*.pyc

#
# Packages
# (it's better to unpack these files and commit the raw source
# git has its own built in compression methods)
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

#
# Logs and databases
dump.rdb
*.log
*.sql
*.sqlite

#
# OS generated files
.DS_Store
.DS_Store?
.Spotlight-V100
.Trashes
Thumbs.db

#
# Secrets / local overrides
*secrets*
*.key
*.local
.env
.env*

#
# Editors
.idea/
.vscode/
*.code-workspace

#
# Python
__pycache__/
*.py[cod]
.venv/

#
# macOS extended attributes
.AppleDouble
.LSOverride
Icon

#
# Node
.npm/
.pnpm-store/

#
# Git identity (keep untracked)
.gitconfig-user
