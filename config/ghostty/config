# themes
theme = dark:NordicPine,light:AlpineDawn

# font
font-family = "SauceCodePro Nerd Font Mono"
font-size = 15
font-thicken = true

# quick terminal
#keybind = global:cmd+grave_accent=toggle_quick_terminal

# clipboard
clipboard-read = allow
clipboard-write = allow
copy-on-select = clipboard

# window
window-padding-x = 8
window-padding-y = 8,0
window-padding-balance = true
window-save-state = always

# transparency & blur
# tried this, marginally preferred it in light mode, didn't like in dark
# not worth the effort to deal with theme switching but leaving here for future experiments
# background-opacity = 0.90
# background-blur-radius = 20

# mouse
mouse-hide-while-typing = true

# titlebar
macos-titlebar-style = transparent

# macos
macos-option-as-alt = true

# update
auto-update-channel = stable
