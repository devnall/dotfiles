#!/usr/bin/env bash
# theme-switch — called by dark-notify when macOS appearance changes
# Usage: theme-switch dark|light

set -euo pipefail

mode="${1:-}"
if [[ "$mode" != "dark" && "$mode" != "light" ]]; then
  echo "Usage: theme-switch dark|light" >&2
  exit 1
fi

# Write state file for shells to read
mkdir -p ~/.local/state
echo "$mode" > ~/.local/state/appearance

# Tmux — source the appropriate theme if tmux is running
if command -v tmux &>/dev/null && tmux list-sessions &>/dev/null; then
  if [[ "$mode" == "dark" ]]; then
    tmux source-file ~/.config/tmux/tmux-nordic.conf
  else
    tmux source-file ~/.config/tmux/tmux-alpine.conf
  fi
fi

# btop — sed the color_theme line (takes effect on next launch)
btop_conf="$HOME/.config/btop/btop.conf"
if [[ -f "$btop_conf" ]]; then
  if [[ "$mode" == "dark" ]]; then
    sed -i '' "s|^color_theme = .*|color_theme = \"${HOME}/.config/btop/themes/rose-pine-moon.theme\"|" "$btop_conf"
  else
    sed -i '' "s|^color_theme = .*|color_theme = \"${HOME}/.config/btop/themes/rose-pine-dawn.theme\"|" "$btop_conf"
  fi
fi

# starship — switch palette (takes effect on next prompt)
starship_conf="$HOME/.config/starship.toml"
if [[ -f "$starship_conf" ]]; then
  if [[ "$mode" == "dark" ]]; then
    sed -i '' 's/^palette = "alpinedawn"/palette = "nordicpine"/' "$starship_conf"
  else
    sed -i '' 's/^palette = "nordicpine"/palette = "alpinedawn"/' "$starship_conf"
  fi
fi
