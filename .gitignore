# Global .gitignore file to keep random crap out of my repos
#
# If setting up a new box, will need to copy/link to ~/ then:
# git config --global core.excludesfile '~/.gitignore'

#
# Vagrant stuff
*.box
/.vagrant/

#
# Bundled Plugins
node_modules/

#
# Temporary Files
*~
*.swp
*.orig

#
# Thumbnails
._*

#
# Config Files
.rvmrc
.ruby-version
.ruby-gemset

#
# Compiled source
*.com
*.class
*.dll
*.exe
*.o
*.so
*.pyc

#
# Packages
# (it's better to unpack these files and commit the raw source
# git has its own built in compression methods)
*.7z
*.dmg
*.gz
*.iso
*.jar
*.rar
*.tar
*.zip

#
# Logs and databases
dump.rdb
*.log
*.sql
*.sqlite

#
# OS generated files
.DS_Store
.DS_Store?
.Spotlight-V100
.Trashes
Thumbs.db

#
# Secrets and local overrides
*.local
*.local.*
.env*
*secrets*
*.key

# Git identity (copy from .gitconfig-*.example; keep untracked)
config/git/.gitconfig-user
config/git/.gitconfig-work
# SSH commit-signing allowers — generated by bootstrap from .gitconfig-user
config/git/allowed_signers

# Claude Code per-machine settings layer — overrides/secrets, merged at install
# (also matched by *.local.* above; listed explicitly for clarity)
config/claude/settings.local.json

# Live theme-switched configs (mutable at runtime, initialized from *.default)
config/btop/btop.conf
config/starship/starship.toml
